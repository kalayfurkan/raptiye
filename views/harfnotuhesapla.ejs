<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <link rel="icon" href="/img/logo.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Harf Notu Hesaplama</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/default.css">
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/harfnotuhesapla.css">
</head>

<body>
    <div id="wrapper">
        <%- include('partials/navbar') %>
            <div class="container">
                <div class="form-container p-4 shadow rounded bg-white">
                    <h2 class="form-title text-center mb-4">Harf Notu Hesaplayıcı</h2>
                    <!-- <p class="lead">Notunuzu ve sınıf ortalamasını girerek yaklaşık harf notunu hesaplayın.</p> -->

                    <form id="gradeForm">
                        <div class="form-group">
                            <label for="studentGrade" class="form-label">Öğrencinin Notu</label>
                            <input type="number" class="form-control" id="studentGrade"
                                placeholder="Öğrencinin notunu girin" required>
                        </div>
                        <div class="form-group">
                            <label for="classAverage" class="form-label">Sınıf Ortalaması</label>
                            <input type="number" class="form-control" id="classAverage"
                                placeholder="Sınıf ortalamasını girin" required>
                        </div>
                        <div class="form-group">
                            <label for="standardDeviation" class="form-label">Standart Sapma</label>
                            <input type="number" class="form-control" id="standardDeviation" value="23"
                                placeholder="Standart sapmayı girin" required>
                        </div>
                        <button type="submit" class="btn">Hesapla</button>
                    </form>
                    <div id="result" class="mt-5 text-center">
                        <!-- Sonuç buraya -->
                    </div>
                </div>
                <div id="info" class="mt-5 text-center">
                    <p>(Havuz dersleri için standart sapma yaklaşık 23 olmaktadır.)</p>
                </div>
            </div>

            <%- include('partials/footer') %>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script src="/js/harfnotuhesapla.js"></script>
</body>

</html>